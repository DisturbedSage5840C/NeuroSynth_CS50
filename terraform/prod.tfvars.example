# Production Terraform variable values — copy to prod.tfvars and fill in real values.
# Never commit prod.tfvars (it is git-ignored).

region             = "us-east-1"
environment        = "prod"
app_name           = "neurosynth"

# Postgres (RDS / Cloud SQL)
db_instance_class  = "db.t3.medium"
db_name            = "neurosynth"
db_username        = "neurosynth_app"
# db_password      — set via TF_VAR_db_password or AWS Secrets Manager

# Redis (ElastiCache)
redis_node_type    = "cache.t3.micro"
redis_num_nodes    = 1

# Compute
api_instance_type  = "t3.small"
api_min_capacity   = 1
api_max_capacity   = 3

# Networking
vpc_cidr           = "10.0.0.0/16"
allowed_cidr_blocks = ["0.0.0.0/0"]
