{
  "id": null,
  "uid": "neurosynth-main",
  "title": "NeuroSynth Platform",
  "tags": ["neurosynth", "ml", "clinical"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(neurosynth_request_count_total[1m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API Latency (p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(neurosynth_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ensemble AUC",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "neurosynth_model_auc{model_name=\"ensemble\"}",
          "legendFormat": "{{disease}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.92 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Model ECE (Calibration Error)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "neurosynth_model_ece{model_name=\"ensemble\"}",
          "legendFormat": "ECE"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Feature Drift PSI",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "neurosynth_drift_psi",
          "legendFormat": "{{feature}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Feature Drift KS Statistic",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "neurosynth_drift_ks",
          "legendFormat": "{{feature}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Drift Severity",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "neurosynth_drift_severity",
          "legendFormat": "Severity"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Gate Status",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "neurosynth_gate_status",
          "legendFormat": "{{gate_name}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Circuit Breaker State",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "neurosynth_circuit_breaker_state",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Inference Errors",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(neurosynth_inference_errors_total[1m])",
          "legendFormat": "{{error_type}}"
        }
      ]
    }
  ]
}
