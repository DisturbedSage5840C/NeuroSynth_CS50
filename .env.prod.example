# NeuroSynth production environment contract
# Copy to .env.prod and inject real values via your secret manager.
# Keys use the NEUROSYNTH_ prefix consumed by backend/core/config.py.

NEUROSYNTH_APP_ENV=prod
NEUROSYNTH_JWT_SECRET=
NEUROSYNTH_PATIENT_HASH_SECRET=
NEUROSYNTH_POSTGRES_DSN=postgresql://postgres:${POSTGRES_PASSWORD}@postgres.prod.internal:5432/neurosynth?sslmode=require
NEUROSYNTH_REDIS_URL=rediss://redis.prod.internal:6379/0
NEUROSYNTH_ALLOWED_ORIGINS=https://api.your-domain.com,https://console.your-domain.com
NEUROSYNTH_AUTH_COOKIE_SECURE=true

# Optional — enables Claude-generated SOAP reports (falls back to template if unset).
ANTHROPIC_API_KEY=
NEUROSYNTH_ANTHROPIC_MODEL=claude-sonnet-4-6

# Container build / registry (deployment infra).
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REPOSITORY=
